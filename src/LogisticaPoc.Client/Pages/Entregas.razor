@page "/entregas"
@inject ILogisticaService Svc
@layout AppLayout

<PageTitle>Entregas – LogisticaPOC</PageTitle>

@if (loading)
{
    <div class="loading-wrap"><div class="loading-spinner"></div><p>Carregando entregas...</p></div>
}
else
{
    <div class="page-header">
        <div>
            <h1>Entregas</h1>
            <p>@entregas.Count() entregas cadastradas</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success">@successMsg</div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger">@errorMsg</div>
    }

    <DeliveryTable Entregas="entregas" OnCreate="OpenCreate" OnSelect="OpenDetail" />
}

@if (showCreate)
{
    <DeliveryForm Visible="true"
                  Motoristas="motoristas"
                  Veiculos="veiculos"
                  Rotas="rotas"
                  OnConfirm="HandleCreate"
                  OnCancel="CloseCreate" />
}

@if (selected is not null)
{
    <div class="modal-backdrop" @onclick="CloseDetail">
        <div class="modal" @onclick:stopPropagation style="max-width:600px">
            <div class="modal-header">
                <div>
                    <h3>@selected.Codigo</h3>
                    <div style="font-size:12px;color:var(--muted);margin-top:3px">Detalhes da entrega</div>
                </div>
                <button class="btn btn-ghost" @onclick="CloseDetail" style="padding:6px">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="detail-row">
                    <span class="detail-label">Status</span>
                    <span class="detail-value"><DeliveryStatusBadge Status="@selected.Status" /></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Destinatário</span>
                    <span class="detail-value" style="font-weight:600">@selected.Destinatario</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Endereço</span>
                    <span class="detail-value">@selected.EnderecoDestino</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Motorista</span>
                    <span class="detail-value">@(selected.MotoristaNome ?? "Não atribuído")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Veículo</span>
                    <span class="detail-value">@(selected.VeiculoPlaca ?? "Não atribuído")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Rota</span>
                    <span class="detail-value">@(selected.RotaNome ?? "—")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Criado em</span>
                    <span class="detail-value">@selected.DataCriacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Previsão</span>
                    <span class="detail-value">@selected.DataPrevista.ToLocalTime().ToString("dd/MM/yyyy")</span>
                </div>
                @if (selected.DataConclusao.HasValue)
                {
                    <div class="detail-row">
                        <span class="detail-label">Concluída em</span>
                        <span class="detail-value">@selected.DataConclusao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(selected.Observacoes))
                {
                    <div class="detail-row">
                        <span class="detail-label">Observações</span>
                        <span class="detail-value">@selected.Observacoes</span>
                    </div>
                }

                <div style="margin-top:20px">
                    <label style="font-size:12.5px;font-weight:600;color:var(--secondary);display:block;margin-bottom:8px">
                        Alterar Status
                    </label>
                    <div class="flex gap-2" style="flex-wrap:wrap">
                        @foreach (var s in Enum.GetValues<StatusEntrega>())
                        {
                            <button class="btn btn-secondary" style="font-size:12.5px;padding:7px 14px"
                                    @onclick="() => UpdateStatus(s)"
                                    disabled="@(selected.Status == s)">
                                @StatusLabel(s)
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] AppLayout? Layout { get; set; }

    private IEnumerable<EntregaDto> entregas = [];
    private IEnumerable<MotoristaDto> motoristas = [];
    private IEnumerable<VeiculoDto> veiculos = [];
    private IEnumerable<RotaDto> rotas = [];
    private bool loading = true;
    private bool showCreate;
    private EntregaDto? selected;
    private string successMsg = "";
    private string errorMsg = "";

    protected override async Task OnInitializedAsync()
    {
        Layout?.SetTitle("Entregas");
        await LoadAll();
    }

    private async Task LoadAll()
    {
        loading = true;
        try
        {
            var tasks = new Task[]
            {
                Task.Run(async () => entregas  = await Svc.GetEntregasAsync()),
                Task.Run(async () => motoristas = await Svc.GetMotoristasAsync()),
                Task.Run(async () => veiculos   = await Svc.GetVeiculosAsync()),
                Task.Run(async () => rotas      = await Svc.GetRotasAsync()),
            };
            await Task.WhenAll(tasks);
        }
        finally { loading = false; }
    }

    private void OpenCreate() => showCreate = true;
    private void CloseCreate() => showCreate = false;
    private void OpenDetail(EntregaDto e) { selected = e; successMsg = ""; errorMsg = ""; }
    private void CloseDetail() => selected = null;

    private async Task HandleCreate(CriarEntregaRequest req)
    {
        try
        {
            await Svc.CriarEntregaAsync(req);
            showCreate = false;
            successMsg = "Entrega criada com sucesso!";
            entregas = await Svc.GetEntregasAsync();
        }
        catch (Exception ex) { errorMsg = $"Erro: {ex.Message}"; }
    }

    private async Task UpdateStatus(StatusEntrega novoStatus)
    {
        if (selected is null) return;
        try
        {
            var updated = await Svc.AtualizarStatusAsync(selected.Id, new(novoStatus, null));
            selected = updated;
            entregas = await Svc.GetEntregasAsync();
            successMsg = $"Status atualizado para {StatusLabel(novoStatus)}.";
        }
        catch (Exception ex) { errorMsg = $"Erro: {ex.Message}"; }
    }

    private static string StatusLabel(StatusEntrega s) => s switch
    {
        StatusEntrega.Pendente   => "Pendente",
        StatusEntrega.EmTransito => "Em Trânsito",
        StatusEntrega.Concluida  => "Concluída",
        StatusEntrega.Atrasada   => "Atrasada",
        StatusEntrega.Cancelada  => "Cancelada",
        _                        => s.ToString()
    };
}
