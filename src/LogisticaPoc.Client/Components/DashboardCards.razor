@* Summary stat cards for the dashboard *@

@if (Dashboard is null)
{
    <div class="loading-wrap"><div class="loading-spinner"></div><p>Carregando...</p></div>
}
else
{
    <div class="stat-grid">
        <StatCard Label="Total de Entregas" Value="@Dashboard.TotalEntregas" ColorClass="dark">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            </svg>
        </StatCard>

        <StatCard Label="Pendentes" Value="@Dashboard.Pendentes" ColorClass="yellow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
        </StatCard>

        <StatCard Label="Em Trânsito" Value="@Dashboard.EmTransito" ColorClass="blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
        </StatCard>

        <StatCard Label="Concluídas" Value="@Dashboard.Concluidas" ColorClass="green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </StatCard>

        <StatCard Label="Atrasadas" Value="@Dashboard.Atrasadas" ColorClass="red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </StatCard>

        <StatCard Label="Motoristas" Value="@Dashboard.TotalMotoristas" SubText="@($"{Dashboard.MotoristasDisponiveis} disponíveis")" ColorClass="orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
        </StatCard>

        <StatCard Label="Veículos" Value="@Dashboard.TotalVeiculos" SubText="@($"{Dashboard.VeiculosDisponiveis} disponíveis")" ColorClass="orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
        </StatCard>
    </div>
}

@code {
    [Parameter, EditorRequired] public DashboardDto? Dashboard { get; set; }
}
